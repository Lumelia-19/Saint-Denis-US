# ============================================
# United Football Saint-Denis (UFSD) - Variables d'environnement
# Copier ce fichier vers .env.local puis renseigner les valeurs.
#   cp .env.local.example .env.local
# ============================================

# --- Formulaire de contact & inscriptions (Resend, côté serveur) ---
# Clé API Resend (https://resend.com) - NE PAS versionner la vraie clé.
RESEND_API_KEY=
# Destinataire des emails du club.
CONTACT_TO_EMAIL=contact@ufsd.fr
# Expéditeur affiché. Tant que le domaine n'est pas vérifié sur Resend,
# garder onboarding@resend.dev. Une fois ufsd.fr vérifié (SPF + DKIM),
# passer à "United Football Saint-Denis <noreply@ufsd.fr>".
CONTACT_FROM_EMAIL="United Football Saint-Denis <onboarding@resend.dev>"

# --- Données de matchs (optionnel, provider distant) ---
# Source des matchs : mock | fff | footclubs | sporteasy | custom
NEXT_PUBLIC_MATCHES_PROVIDER=mock
# URL de l'API matchs (si provider distant).
NEXT_PUBLIC_MATCHES_API_URL=
# Clé d'API matchs (si provider distant).
NEXT_PUBLIC_MATCHES_API_KEY=
# Identifiant du club auprès du provider.
NEXT_PUBLIC_CLUB_ID=UFSD93
